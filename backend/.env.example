# Environment Variables — Event Ticketing System
# Copy this file to .env and fill in your values. Never commit .env to Git.

# ── Server ────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_IDLE_TIME=30m

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRY_MINUTES=60           # 15–60 minutes; 60 recommended

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
